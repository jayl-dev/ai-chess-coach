SERVER_HOST=0.0.0.0
SERVER_PORT=5174

# Optional screenshot-host identity and fixed six-digit pairing code.
# Leave the code blank to generate a new code each time the host starts.
HOST_NAME=
HOST_PAIRING_CODE=

# Optional HTTPS certificate and private-key paths for pairing from an HTTPS PWA.
# Relative paths resolve from the repository root. Both values are required for HTTPS.
HOST_HTTPS_CERT=
HOST_HTTPS_KEY=

# Optional source-code link shown by the app.
VITE_SOURCE_CODE_URL=

# Development-only client fallbacks. Never place production keys in VITE_* variables.
VITE_DEV_OPENROUTER_API_KEY=
VITE_DEV_GEMINI_API_KEY=

# Optional environment flag to enable mock analysis mode (defaults to false)
VITE_MOCK=false
