{
  "name": "chess-coach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0 --config client/vite.config.ts",
    "dev:host": "cross-env NODE_ENV=development tsx watch --clear-screen=false --exclude \"client/**\" server/src/index.ts",
    "dev:app": "vite --host 0.0.0.0 --config client/vite.config.ts",
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build -w client",
    "preview:cloudflare": "npm run build:app && wrangler dev",
    "deploy:cloudflare": "npm run build:app && wrangler deploy",
    "deploy:pages": "npm run build:app && wrangler pages deploy client/dist --project-name=ai-chess-coach",
    "start": "cross-env NODE_ENV=production node server/dist/index.js",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.2",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "sharp": "^0.35.0"
  }
}
